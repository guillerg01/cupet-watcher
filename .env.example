# --- Database ---
DATABASE_URL="postgresql://cupet:cupet@localhost:5432/cupet?schema=public"

# --- xutil API ---
XUTIL_BASE="https://ticket.xutil.net/apps/bienestar/api"
XUTIL_OAUTH_URL="https://ticket.xutil.net/oauth2/token"
XUTIL_APP_HEADER="agencia-citas"
# OAuth client id (JWT 'aud'). Optional — only if password grant requires it.
XUTIL_CLIENT_ID=""
# Scraper service account (rotate the leaked one before using!)
XUTIL_SCRAPER_USER=""
XUTIL_SCRAPER_PASS=""

# --- Email (Resend) ---
RESEND_API_KEY=""
EMAIL_FROM="Cupet Watcher <alerts@yourdomain.com>"

# --- App auth (NextAuth / Auth.js) ---
AUTH_SECRET="change-me-openssl-rand-base64-32"

# --- Token encryption (AES-256-GCM). 32-byte key, base64. openssl rand -base64 32 ---
ENCRYPTION_KEY="change-me-32-byte-base64-key"

# --- Scraper tuning ---
SCRAPE_PAGE_DELAY_MS_MIN="300"
SCRAPE_PAGE_DELAY_MS_MAX="800"
SCRAPE_CATALOG_CRON="0 * * * *"
SCRAPE_AVAILABILITY_CRON="*/20 * * * *"
SEND_NOTIFICATIONS_CRON="*/2 * * * *"
