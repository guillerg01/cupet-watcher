# --- Database ---
DATABASE_URL="postgresql://cupet:cupet@localhost:5434/cupet?schema=public"

# --- xutil API ---
XUTIL_BASE="https://ticket.xutil.net/apps/bienestar/api"
XUTIL_OAUTH_URL="https://ticket.xutil.net/oauth2/token"
XUTIL_APP_HEADER="agencia-citas"
# OAuth client credentials (embedded in the xutil SPA — same as browser login)
XUTIL_OAUTH_CLIENT_ID="6Z2XcgkMQkXtUWCxy6y7eOK2ZIAa"
XUTIL_OAUTH_CLIENT_SECRET="WHkjL78tUHlwMPj7fd_FF5kU2hIa"
# Scraper account for catalog/availability jobs (not end-user login)
XUTIL_SCRAPER_USER=""
XUTIL_SCRAPER_PASS=""
# Node on Windows: win-ca loads system certs automatically. Set true only if TLS still fails.
XUTIL_TLS_INSECURE="false"
# Verbose xutil request logs (worker / scrape debugging)
XUTIL_DEBUG="false"

# --- Email (Resend) ---
RESEND_API_KEY=""
# Dominio verificado en Resend (no sirve *.onrender.com). Pruebas: onboarding@resend.dev
EMAIL_FROM="Cupet Watcher <onboarding@resend.dev>"

# --- App auth (NextAuth / Auth.js) ---
AUTH_SECRET="change-me-openssl-rand-base64-32"

# openssl rand -base64 32
ENCRYPTION_KEY="change-me-32-byte-base64-key"

# --- Scraper tuning ---
SCRAPE_PAGE_DELAY_MS_MIN="3500"
SCRAPE_PAGE_DELAY_MS_MAX="7000"
SCRAPE_RATE_LIMIT_COOLDOWN_MS="10000"
# Full check: catalog, availability, queues, then email alerts (every 2 hours)
WORKER_CHECK_CRON="0 */2 * * *"
PREDICT_CRON="0 */6 * * *"
