{
  "expo": {
    "name": "Cupet Watcher",
    "slug": "cupet-watcher",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "cupetwatcher",
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "net.cupetwatcher.app",
      "permissions": [
        "INTERNET",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_DATA_SYNC",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK"
      ]
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "UIBackgroundModes": ["fetch", "processing"]
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-notifications"
    ],
    "extra": {
      "backendUrl": "http://10.0.2.2:3000"
    }
  }
}
